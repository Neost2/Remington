generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DRIVER
  COORDINATOR
  ADMIN
  PARTNER
  ADVOCATE
}

enum AccessibilityRequirement {
  STANDARD
  WHEELCHAIR_ACCESSIBLE
  NON_TRANSFERABLE_WHEELCHAIR
  STRETCHER
}

enum SchedulingConstraint {
  STANDARD
  SAME_DAY
  ADVANCE_48H
  ADVANCE_72H
}

enum UrgencyLevel {
  NORMAL
  HIGH
  CRITICAL
}

enum RideStatus {
  PENDING
  MATCHED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FALLBACK_NEEDED
}

enum AppointmentType {
  ONCOLOGY
  CARDIOLOGY
  NEUROLOGY
  DIALYSIS
  MENTAL_HEALTH
  POST_SURGICAL
  SPECIALIST
  OTHER
}

enum CreditStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

// ─── Payment & Funding Enums ──────────────────────────────────────────────────

enum FundingSource {
  MEDICAID_NEMT
  MEDICARE
  PRIVATE_INSURANCE
  CREDIT_CARD
  GRANT
  HSA_FSA
  FAMILY
  PARTNER_CREDIT
  CHARITY
  OTHER
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  REALLOCATED
  FAILED
}

enum TransportationProviderType {
  NEMT_VAN
  RIDESHARE
  TAXI
  VOLUNTEER_DRIVER
  PUBLIC_TRANSIT
  COMMUNITY_SHUTTLE
  WHEELCHAIR_VAN
  AMBULETTE
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient           Patient?
  driver            Driver?
  coordinator       Coordinator?
  partner           InstitutionalPartner?
  advocate          Advocate?
  communicationLogs CommunicationLog[]

  @@map("users")
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county          String
  state           String
  zipCode         String
  hasSmartphone   Boolean @default(false)
  prefersSms      Boolean @default(true)
  prefersVoice    Boolean @default(false)
  primaryLanguage String  @default("English")
  notes                    String?

  // Structured accessibility and scheduling constraints
  accessibilityRequirement AccessibilityRequirement @default(STANDARD)
  schedulingConstraint     SchedulingConstraint     @default(STANDARD)

  // Equity & Demographics
  raceEthnicity   String?
  disability      String?
  incomeBracket   String?
  barriers        String?

  // Default funding source for payment routing
  defaultFundingSource FundingSource? @default(MEDICAID_NEMT)
  primaryInsuranceProvider String?

  appointments RideRequest[]
  payments     PaymentAuthorization[]
  surveys      SurveyResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patients")
}

// ─── Driver ───────────────────────────────────────────────────────────────────

model Driver {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county           String
  state            String
  vehicleCapacity          Int     @default(4)
  isInFallbackPool         Boolean @default(false)
  isAvailableNow           Boolean @default(false)
  maxMilesOneWay           Int     @default(50)
  isWheelchairAccessible   Boolean @default(false)
  preferredDays    String?
  communityNotes   String?
  ridesCompleted   Int     @default(0)
  reliabilityScore Float   @default(5.0)

  // Provider type and payment acceptance
  providerType     TransportationProviderType @default(VOLUNTEER_DRIVER)
  acceptsCreditCard  Boolean @default(false)
  acceptsMedicaid    Boolean @default(false)
  acceptsGrantPay    Boolean @default(true)
  perMileRateCents   Int?
  baseFeeCents       Int?

  rides          RideRequest[]
  depotRoutes    DepotRouteDriver[]
  notifications  Notification[]
  advocateRides  AdvocateRideRequest[]
  fallbackOptions FallbackOffer[]
  surveys        SurveyResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}

// ─── Coordinator ──────────────────────────────────────────────────────────────

model Coordinator {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county      String
  state       String
  organization String?
  stipendActive Boolean @default(false)
  isVerified   Boolean @default(false)

  rideRequests  RideRequest[]
  depotRoutes   DepotRoute[]
  notifications Notification[]
  advocateRides AdvocateRideRequest[]
  surveys       SurveyResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coordinators")
}

// ─── Institutional Partner ────────────────────────────────────────────────────

model InstitutionalPartner {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization String
  county       String
  state        String
  isVerified   Boolean @default(false)

  credits       RideCredit[]
  advocateRides AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutional_partners")
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id              String          @id @default(cuid())
  appointmentType AppointmentType
  clinicName      String
  clinicCity      String
  clinicState     String
  appointmentDate DateTime
  estimatedMiles  Int
  isRecurring     Boolean         @default(false)
  recurrenceNote  String?
  notes           String?

  // Health Impact
  wasMissed            Boolean?  @default(false)
  missedReason         String?
  impactNotes          String?

  // Rescheduling chain
  rescheduledFromId    String?
  rescheduledFrom      Appointment?  @relation("ReschedulingChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo        Appointment[] @relation("ReschedulingChain")

  rideRequest RideRequest?

  @@map("appointments")
}

// ─── Ride Event Logging ──────────────────────────────────────────────────────

model RideEvent {
  id            String      @id @default(cuid())
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  eventType     String
  oldStatus     RideStatus?
  newStatus     RideStatus?
  reason        String?
  actorRole     Role?
  actorId       String?
  createdAt     DateTime    @default(now())

  @@map("ride_events")
}

// ─── Survey / Satisfaction ───────────────────────────────────────────────────

model SurveyResponse {
  id            String      @id @default(cuid())
  rideRequestId String?
  rideRequest   RideRequest? @relation(fields: [rideRequestId], references: [id])
  patientId     String?
  patient       Patient?    @relation(fields: [patientId], references: [id])
  driverId      String?
  driver        Driver?     @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  npsScore      Int?
  satisfaction  Int?
  comments      String?
  submittedAt   DateTime    @default(now())

  @@map("survey_responses")
}

// ─── Ride Cost & ROI ─────────────────────────────────────────────────────────

model RideCostLog {
  id            String      @id @default(cuid())
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  costCents     Int
  fundingSource String
  estimatedSavingsCents Int?
  notes         String?
  createdAt     DateTime    @default(now())

  @@map("ride_cost_logs")
}

// ─── Communication Engagement ────────────────────────────────────────────────

model CommunicationLog {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  channel       String
  direction     String
  message       String?
  status        String?
  relatedId     String?
  createdAt     DateTime    @default(now())

  @@map("communication_logs")
}

// ─── Ride Request ─────────────────────────────────────────────────────────────

model RideRequest {
  id            String     @id @default(cuid())
  patientId     String
  patient       Patient    @relation(fields: [patientId], references: [id])
  appointmentId String     @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  driverId      String?
  driver        Driver?    @relation(fields: [driverId], references: [id])
  creditId      String?
  credit        RideCredit? @relation(fields: [creditId], references: [id])

  status                   RideStatus           @default(PENDING)
  urgencyLevel             UrgencyLevel         @default(NORMAL)
  pickupAddress            String
  pickupTime               DateTime
  confirmedAt              DateTime?
  completedAt              DateTime?
  cancelledAt              DateTime?
  cancellationNote         String?
  isFallbackUsed           Boolean              @default(false)
  patientNoShow            Boolean              @default(false)
  needsSameDayFallback     Boolean              @default(false)
  requestedAdvanceWindowHours Int?
  rescheduledFromRideId    String?

  // ─── Payment & Provider Fields ────────────────────────────────────────────
  fundingSource            FundingSource?
  providerType             TransportationProviderType?
  paymentAuthorizationId   String?
  paymentAuthorization     PaymentAuthorization? @relation("RidePaymentAuthorization", fields: [paymentAuthorizationId], references: [id])

  notifications Notification[]
  events        RideEvent[]
  ridePayment   RidePayment? @relation("RidePaymentToRideRequest")
  costLogs      RideCostLog[]
  fallbackOffers FallbackOffer[]
  surveys       SurveyResponse[]
  advocateRides AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ride_requests")
}

// ─── Ride Payment (captures payment at ride level) ──────────────────────────

model RidePayment {
  id            String      @id @default(cuid())
  rideRequestId String      @unique
  rideRequest   RideRequest @relation("RidePaymentToRideRequest", fields: [rideRequestId], references: [id], onDelete: Cascade)

  // Amount breakdown in cents
  totalCents        Int
  baseFeeCents      Int      @default(0)
  mileageCents      Int      @default(0)
  surchargeCents    Int      @default(0)
  tipCents          Int      @default(0)

  // Payment routing
  fundingSource     FundingSource
  paymentStatus     PaymentStatus @default(PENDING)
  paidByPatient     Boolean       @default(false)
  patientPortionCents Int         @default(0)

  // Timestamps
  authorizedAt  DateTime?
  capturedAt    DateTime?
  refundedAt    DateTime?
  reallocatedAt DateTime?
  notes         String?

  transactions  PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ride_payments")
}

// ─── Payment Transaction Trail ──────────────────────────────────────────────

model PaymentTransaction {
  id            String      @id @default(cuid())
  ridePaymentId String
  ridePayment   RidePayment @relation(fields: [ridePaymentId], references: [id], onDelete: Cascade)

  transactionType String
  amountCents     Int
  currency        String     @default("USD")
  status          PaymentStatus
  gatewayReference String?
  gatewayResponse String?
  processedBy     String?
  notes           String?

  // For reallocations
  reallocatedFromProviderType TransportationProviderType?
  reallocatedToProviderType   TransportationProviderType?
  reallocatedToDriverId       String?

  createdAt DateTime @default(now())

  @@map("payment_transactions")
}

// ─── Payment Authorization (pre-ride funding approval) ─────────────────────

model PaymentAuthorization {
  id            String      @id @default(cuid())
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])

  fundingSource FundingSource
  maxCents      Int
  usedCents     Int         @default(0)
  status        PaymentStatus @default(AUTHORIZED)

  authorizationReference String?
  authorizationCode      String?
  expiresAt              DateTime?
  notes                  String?

  // Which rides were authorized under this
  rides RideRequest[] @relation("RidePaymentAuthorization")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_authorizations")
}

// ─── Fallback Offer (alternative transportation when primary fails) ─────────

model FallbackOffer {
  id            String      @id @default(cuid())
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        Driver?     @relation(fields: [driverId], references: [id])

  providerType  TransportationProviderType
  providerName  String
  estimatedCostCents Int?
  estimatedArrivalMinutes Int?
  isAvailable          Boolean   @default(true)
  isWheelchairAccessible Boolean @default(false)
  acceptanceRate       Float?

  // Selection tracking
  wasOfferedToPatient Boolean   @default(false)
  patientRespondedAt  DateTime?
  wasAccepted         Boolean?
  patientResponseNote String?

  // Auto-match rank (lower = better)
  autoMatchRank Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fallback_offers")
}

// ─── Advocate ─────────────────────────────────────────────────────────────────

model Advocate {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   String?
  county         String
  state          String
  isVerified     Boolean @default(false)
  specialization String?

  advocateRides  AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("advocates")
}

// Joins an advocate to a ride they are coordinating on behalf of a patient
model AdvocateRideRequest {
  id            String      @id @default(cuid())
  advocateId    String
  advocate      Advocate    @relation(fields: [advocateId], references: [id])
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  driverId      String?
  driver        Driver?     @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  partnerId     String?
  partner       InstitutionalPartner? @relation(fields: [partnerId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([advocateId, rideRequestId])
  @@map("advocate_ride_requests")
}

// ─── Depot Route (Scheduled Community Runs) ───────────────────────────────────

model DepotRoute {
  id            String  @id @default(cuid())
  coordinatorId String
  coordinator   Coordinator @relation(fields: [coordinatorId], references: [id])
  depotName     String
  depotAddress  String
  county        String
  state         String
  destinationCity  String
  destinationState String
  departureTime    DateTime
  returnTime       DateTime?
  maxPassengers    Int       @default(6)
  isActive         Boolean   @default(true)
  recurrenceNote   String?

  drivers DepotRouteDriver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("depot_routes")
}

model DepotRouteDriver {
  id           String     @id @default(cuid())
  depotRouteId String
  depotRoute   DepotRoute @relation(fields: [depotRouteId], references: [id])
  driverId     String
  driver       Driver     @relation(fields: [driverId], references: [id])
  confirmedAt  DateTime?

  @@unique([depotRouteId, driverId])
  @@map("depot_route_drivers")
}

// ─── Ride Credits (Prepay / Layaway) ─────────────────────────────────────────

model RideCredit {
  id        String               @id @default(cuid())
  partnerId String
  partner   InstitutionalPartner @relation(fields: [partnerId], references: [id])
  totalCredits     Int
  usedCredits      Int            @default(0)
  remainingCredits Int
  status           CreditStatus   @default(ACTIVE)
  expiresAt        DateTime?
  notes            String?

  rides RideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ride_credits")
}

// ─── Notifications (SMS / Voice) ──────────────────────────────────────────────

model Notification {
  id            String  @id @default(cuid())
  rideRequestId String?
  rideRequest   RideRequest? @relation(fields: [rideRequestId], references: [id])
  driverId      String?
  driver        Driver?      @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])

  channel   String
  recipient String
  message   String
  sentAt    DateTime?
  delivered Boolean  @default(false)
  twilioSid String?

  createdAt DateTime @default(now())

  @@map("notifications")
}