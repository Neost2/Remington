generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DRIVER
  COORDINATOR
  ADMIN
  PARTNER
  ADVOCATE
}

enum AccessibilityRequirement {
  STANDARD
  WHEELCHAIR_ACCESSIBLE
  NON_TRANSFERABLE_WHEELCHAIR
  STRETCHER
}

enum SchedulingConstraint {
  STANDARD
  SAME_DAY
  ADVANCE_48H
  ADVANCE_72H
}

enum UrgencyLevel {
  NORMAL
  HIGH
  CRITICAL
}

enum RideStatus {
  PENDING
  MATCHED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FALLBACK_NEEDED
}

enum AppointmentType {
  ONCOLOGY
  CARDIOLOGY
  NEUROLOGY
  DIALYSIS
  MENTAL_HEALTH
  POST_SURGICAL
  SPECIALIST
  OTHER
}

enum CreditStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient     Patient?
  driver      Driver?
  coordinator Coordinator?
  partner     InstitutionalPartner?
  advocate    Advocate?

  @@map("users")
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county          String
  state           String
  zipCode         String
  hasSmartphone   Boolean @default(false)
  prefersSms      Boolean @default(true)
  prefersVoice    Boolean @default(false)
  primaryLanguage String  @default("English")
  notes                    String?  // coordinator-visible notes (no diagnosis stored here)

  // Structured accessibility and scheduling constraints
  accessibilityRequirement AccessibilityRequirement @default(STANDARD)
  schedulingConstraint     SchedulingConstraint     @default(STANDARD)

  // Equity & Demographics
  raceEthnicity   String?
  disability      String?  // free-text supplement to accessibilityRequirement
  incomeBracket   String?
  barriers        String?  // JSON array or comma-separated: ["language","mobility","tech"]

  appointments RideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patients")
}

// ─── Driver ───────────────────────────────────────────────────────────────────

model Driver {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county           String
  state            String
  vehicleCapacity          Int     @default(4)
  isInFallbackPool         Boolean @default(false) // rapid-response roster
  isAvailableNow           Boolean @default(false)
  maxMilesOneWay           Int     @default(50)
  isWheelchairAccessible   Boolean @default(false)
  preferredDays    String? // JSON array of days e.g. ["MON","WED","FRI"]
  communityNotes   String? // why they volunteer — visible to coordinators
  ridesCompleted   Int     @default(0)
  reliabilityScore Float   @default(5.0)

  rides          RideRequest[]
  depotRoutes    DepotRouteDriver[]
  notifications  Notification[]
  advocateRides  AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}

// ─── Coordinator ──────────────────────────────────────────────────────────────

model Coordinator {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  county      String
  state       String
  organization String? // church, clinic, nonprofit, etc.
  stipendActive Boolean @default(false)
  isVerified   Boolean @default(false)

  rideRequests  RideRequest[]
  depotRoutes   DepotRoute[]
  notifications Notification[]
  advocateRides AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coordinators")
}

// ─── Institutional Partner ────────────────────────────────────────────────────

model InstitutionalPartner {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization String
  county       String
  state        String
  isVerified   Boolean @default(false)

  credits       RideCredit[]
  advocateRides AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutional_partners")
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id              String          @id @default(cuid())
  appointmentType AppointmentType
  clinicName      String
  clinicCity      String
  clinicState     String
  appointmentDate DateTime
  estimatedMiles  Int
  isRecurring     Boolean         @default(false)
  recurrenceNote  String?         // e.g. "every Tuesday"
  notes           String?

  // Health Impact
  wasMissed            Boolean?  @default(false)
  missedReason         String?
  impactNotes          String?

  // Rescheduling chain — links a rescheduled appointment back to the original
  rescheduledFromId    String?
  rescheduledFrom      Appointment?  @relation("ReschedulingChain", fields: [rescheduledFromId], references: [id])
  rescheduledTo        Appointment[] @relation("ReschedulingChain")
// ─── Ride Event Logging ──────────────────────────────────────────────────────

model RideEvent {
  id            String      @id @default(cuid())
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  eventType     String      // e.g. "STATUS_CHANGE", "FALLBACK_TRIGGERED", "NO_SHOW", "CANCELLED"
  oldStatus     RideStatus?
  newStatus     RideStatus?
  reason        String?
  actorRole     Role?       // who triggered the event
  actorId       String?
  createdAt     DateTime    @default(now())

  @@map("ride_events")
}

// ─── Survey / Satisfaction ───────────────────────────────────────────────────

model SurveyResponse {
  id            String      @id @default(cuid())
  rideRequestId String?
  rideRequest   RideRequest? @relation(fields: [rideRequestId], references: [id])
  patientId     String?
  patient       Patient?    @relation(fields: [patientId], references: [id])
  driverId      String?
  driver        Driver?     @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  npsScore      Int?        // 0-10
  satisfaction  Int?        // 1-5
  comments      String?
  submittedAt   DateTime    @default(now())

  @@map("survey_responses")
}

// ─── Ride Cost & ROI ─────────────────────────────────────────────────────────

model RideCostLog {
  id            String      @id @default(cuid())
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  costCents     Int         // cost in cents
  fundingSource String      // e.g. "GRANT", "MEDICAID", "PRIVATE", "FAMILY"
  estimatedSavingsCents Int?
  notes         String?
  createdAt     DateTime    @default(now())

  @@map("ride_cost_logs")
}

// ─── Communication Engagement ────────────────────────────────────────────────

model CommunicationLog {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  channel       String      // "sms", "voice", "email"
  direction     String      // "sent", "received"
  message       String?
  status        String?     // "delivered", "failed", "opt_out", "responded"
  relatedId     String?     // e.g. rideRequestId, notificationId
  createdAt     DateTime    @default(now())

  @@map("communication_logs")
}

// ─── Ride Request ─────────────────────────────────────────────────────────────

model RideRequest {
  id            String     @id @default(cuid())
  patientId     String
  patient       Patient    @relation(fields: [patientId], references: [id])
  appointmentId String     @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  driverId      String?
  driver        Driver?    @relation(fields: [driverId], references: [id])
  creditId      String?
  credit        RideCredit? @relation(fields: [creditId], references: [id])

  status                   RideStatus           @default(PENDING)
  urgencyLevel             UrgencyLevel         @default(NORMAL)
  pickupAddress            String
  pickupTime               DateTime
  confirmedAt              DateTime?
  completedAt              DateTime?
  cancelledAt              DateTime?
  cancellationNote         String?
  isFallbackUsed           Boolean              @default(false)
  patientNoShow            Boolean              @default(false)
  needsSameDayFallback     Boolean              @default(false)
  requestedAdvanceWindowHours Int?              // e.g. 72 for Medicaid scheduling windows
  rescheduledFromRideId    String?              // links to prior ride if this is a reschedule

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ride_requests")
}

// ─── Advocate ─────────────────────────────────────────────────────────────────
// Represents veteran advocates, informal coordinators, and advocacy orgs
// who arrange transportation on behalf of patients outside clinic referral paths.

model Advocate {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   String? // e.g. "Veterans Transportation Alliance"
  county         String
  state          String
  isVerified     Boolean @default(false)
  specialization String? // e.g. "veteran", "dialysis", "pediatric"

  advocateRides  AdvocateRideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("advocates")
}

// Joins an advocate to a ride they are coordinating on behalf of a patient
model AdvocateRideRequest {
  id            String      @id @default(cuid())
  advocateId    String
  advocate      Advocate    @relation(fields: [advocateId], references: [id])
  rideRequestId String
  rideRequest   RideRequest @relation(fields: [rideRequestId], references: [id])
  driverId      String?
  driver        Driver?     @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])
  partnerId     String?
  partner       InstitutionalPartner? @relation(fields: [partnerId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([advocateId, rideRequestId])
  @@map("advocate_ride_requests")
}

// ─── Depot Route (Scheduled Community Runs) ───────────────────────────────────

model DepotRoute {
  id            String  @id @default(cuid())
  coordinatorId String
  coordinator   Coordinator @relation(fields: [coordinatorId], references: [id])
  depotName     String  // "First Baptist Church parking lot"
  depotAddress  String
  county        String
  state         String
  destinationCity  String
  destinationState String
  departureTime    DateTime
  returnTime       DateTime?
  maxPassengers    Int       @default(6)
  isActive         Boolean   @default(true)
  recurrenceNote   String?   // "Every Tuesday"

  drivers DepotRouteDriver[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("depot_routes")
}

model DepotRouteDriver {
  id           String     @id @default(cuid())
  depotRouteId String
  depotRoute   DepotRoute @relation(fields: [depotRouteId], references: [id])
  driverId     String
  driver       Driver     @relation(fields: [driverId], references: [id])
  confirmedAt  DateTime?

  @@unique([depotRouteId, driverId])
  @@map("depot_route_drivers")
}

// ─── Ride Credits (Prepay / Layaway) ─────────────────────────────────────────

model RideCredit {
  id        String               @id @default(cuid())
  partnerId String
  partner   InstitutionalPartner @relation(fields: [partnerId], references: [id])
  totalCredits     Int
  usedCredits      Int            @default(0)
  remainingCredits Int
  status           CreditStatus   @default(ACTIVE)
  expiresAt        DateTime?
  notes            String?

  rides RideRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ride_credits")
}

// ─── Notifications (SMS / Voice) ──────────────────────────────────────────────

model Notification {
  id            String  @id @default(cuid())
  rideRequestId String?
  rideRequest   RideRequest? @relation(fields: [rideRequestId], references: [id])
  driverId      String?
  driver        Driver?      @relation(fields: [driverId], references: [id])
  coordinatorId String?
  coordinator   Coordinator? @relation(fields: [coordinatorId], references: [id])

  channel   String  // "sms" | "voice" | "email"
  recipient String  // phone number or email
  message   String
  sentAt    DateTime?
  delivered Boolean  @default(false)
  twilioSid String?

  createdAt DateTime @default(now())

  @@map("notifications")
}
